# Copy to .env — docker-compose and the API both read this file.

# --- Postgres ---
POSTGRES_USER=dash
POSTGRES_PASSWORD=dash
POSTGRES_DB=dash
POSTGRES_PORT=5432

# --- API ---
API_PORT=4000
DATABASE_URL=postgres://dash:dash@localhost:5432/dash
# Postgres schema for the app's tables (created on boot if missing). The API
# sets it as the connection search_path, so all migrations and queries land
# there. Leave as `public` unless you share the database with other apps.
DB_SCHEMA=public
CORS_ORIGIN=http://localhost:5173
# Log verbosity: trace | debug | info | warn | error | fatal. Logs are emitted
# as Elastic Common Schema (ECS) JSON. Unset defaults to `info` in production
# and `debug` everywhere else.
LOG_LEVEL=

# --- Auth ---
# The single shared admin token that unlocks the dashboard. Anyone with it gets
# full access; a successful login sets an 8h cookie so it isn't asked again.
# Change this to your own secret. This is the entire login story.
STATIC_LOGIN_TOKEN=let-me-in

# --- OTLP ingest (Claude Code telemetry) ---
# The API accepts OTLP/HTTP JSON exports on /v1/metrics and /v1/logs — these
# are the only endpoints outside the dashboard login. When set, exporters must
# send `Authorization: Bearer <token>`; leave empty to keep the ingest open
# for local development. Point Claude Code at it with:
#   CLAUDE_CODE_ENABLE_TELEMETRY=1
#   OTEL_METRICS_EXPORTER=otlp
#   OTEL_LOGS_EXPORTER=otlp
#   OTEL_EXPORTER_OTLP_PROTOCOL=http/json
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4000
#   OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer <token>"   # if set below
OTLP_INGEST_TOKEN=

# --- Copilot data source ---
# mock   = seeded 1,000-seat generator, no credentials needed (default)
# github = live GitHub Copilot seats + metrics-reports APIs (see docs/github-integration.md)
COPILOT_SOURCE=mock

# PAT scopes: manage_billing:copilot (or read:org) — covers both the seats
# endpoint and the copilot/metrics/reports endpoints. Must be SSO-authorised
# for the org if the enterprise enforces SAML.
GITHUB_TOKEN=
GITHUB_ORG=
# Metrics-reports API version. Bump only if GitHub deprecates this one.
GITHUB_API_VERSION=2026-03-10

# --- JIRA Insight (identity sync) ---
# Optional, set together or not at all. When set, POST /api/jira/sync resolves
# the saml ids from the user export against JIRA Insight and fills jira_people.
# Left unset, the sync answers 503 — except with COPILOT_SOURCE=mock, where it
# generates deterministic people for the mock roster instead. The app never
# calls JIRA at read time.
JIRA_BASE_URL=
JIRA_TOKEN=
