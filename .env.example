# Copy to .env — docker-compose and the API both read this file.

# --- Postgres ---
POSTGRES_USER=dash
POSTGRES_PASSWORD=dash
POSTGRES_DB=dash
POSTGRES_PORT=5432

# --- API ---
API_PORT=4000
DATABASE_URL=postgres://dash:dash@localhost:5432/dash
CORS_ORIGIN=http://localhost:5173

# --- Copilot data source ---
# mock   = seeded 1,000-seat generator, no credentials needed (default)
# github = live GitHub Copilot seats + metrics-reports APIs (see docs/github-integration.md)
COPILOT_SOURCE=mock

# PAT scopes: manage_billing:copilot (or read:org) — covers both the seats
# endpoint and the copilot/metrics/reports endpoints. Must be SSO-authorised
# for the org if the enterprise enforces SAML.
GITHUB_TOKEN=
GITHUB_ORG=
# Metrics-reports API version. Bump only if GitHub deprecates this one.
GITHUB_API_VERSION=2026-03-10
